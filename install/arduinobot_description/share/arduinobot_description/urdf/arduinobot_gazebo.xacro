<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="arduinobot">

  <!-- Gazebo ros2_control plugin -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <robot_param>robot_description</robot_param>
      <parameters>$(find arduinobot_controller)/config/arduinobot_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- Materials for links -->
  <gazebo reference="base_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="base_plate">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="forward_drive_arm">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="horizontal_arm">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="claw_support">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- End-effector camera (ATTACHED TO ee_camera_link) -->
  <gazebo reference="ee_camera_link">
    <sensor name="ee_camera" type="camera">
      <update_rate>30</update_rate>

      <!-- Pose relative to ee_camera_link (keep 0; control pose via the fixed joint in URDF) -->
      <pose>0 0 0 0 0 0</pose>

      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>10</far>
        </clip>
      </camera>

      <plugin name="ee_camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/ee_camera</namespace>
        </ros>

        <camera_name>ee_camera</camera_name>
        <image_topic_name>image_raw</image_topic_name>
        <camera_info_topic_name>camera_info</camera_info_topic_name>

        <!-- Publish TF frame id -->
        <frame_name>ee_camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>

